# Copy this file to `.env` and adjust if you want a real provider.
#
#   cp .env.example .env
#
# The default needs NO key — the whole repo runs offline on the mock provider.
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Which provider should the app use?
#
#   mock   -> deterministic, offline, in-process model    (no key, the default)
#   openai -> OpenAI chat                                  (needs OPENAI_API_KEY)
#   claude -> Claude messages                              (needs ANTHROPIC_API_KEY)
#
# The production stack (observability, cost, retries, caching, guardrails,
# prompt versioning, eval gates) is identical on all three — only this line and
# the key change.
# ---------------------------------------------------------------------------
PROVIDER=mock

# Flip PROVIDER to a real stack but forget `secrun` (so the key isn't on the
# environment) and the code won't crash — it degrades to the offline mock, loudly
# (a stderr banner + an "Active provider: mock (FALLBACK: ...)" line). That keeps
# you running, but it is NOT the real model. Set PROVIDER_STRICT=1 to turn the
# missing key back into a hard error instead — do this in CI and any real
# eval/cost run, where a silent mock would quietly poison your numbers.
# PROVIDER_STRICT=1

# Which prompt version to serve (files live in prompts/*.txt). Default: v2.
PROMPT_VERSION=v2

# --- API keys (optional) are NOT stored here ---
# The default mock needs no key. To use a real provider, store its key in your OS
# keychain and inject it per-command with `secrun` (setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys
